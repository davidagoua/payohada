:80 {
    # Set the root directory for the static site
    root * /srv

    # Redirect /api to /api/ to ensure it hits the handle_path directive
    redir /api /api/

    # Route all requests starting with /api/ to the backend container,
    # stripping the /api prefix before forwarding.
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    # Serve static files and fallback to index.html for client-side routing (SPA)
    handle {
        try_files {path} {path}/ /index.html
        file_server
    }

    # Enable compression
    encode gzip zstd

    # Log requests
    log {
        output stdout
    }
}
